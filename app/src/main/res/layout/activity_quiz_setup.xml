<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:padding="24dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academic Architect"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODULE PREPARATION"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/colorSurfaceVariant"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvSubjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Computer Science"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Assess your architectural understanding of computational systems and algorithmic complexity."
                android:textColor="?attr/colorOutline"
                android:textSize="16sp"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complexity Level"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEasy"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Easy"
                        android:textColor="?attr/colorOutline"
                        android:textAlignment="viewStart"
                        app:backgroundTint="?attr/colorSurface"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/radiobutton_off_background"
                        app:iconGravity="end"
                        app:iconTint="?attr/colorOutline"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMedium"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Medium"
                        android:textColor="?attr/colorOnPrimary"
                        android:textAlignment="viewStart"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/radiobutton_on_background"
                        app:iconGravity="end"
                        app:iconTint="?attr/colorOnPrimary"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHard"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Hard"
                        android:textColor="?attr/colorOutline"
                        android:textAlignment="viewStart"
                        app:backgroundTint="?attr/colorSurface"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/radiobutton_off_background"
                        app:iconGravity="end"
                        app:iconTint="?attr/colorOutline"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test Parameters"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Randomized Sequence\n• 25 Minute Temporal Constraint\n• 25 Questions"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingExtra="8dp"
                        android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBeginAssessment"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Begin Assessment"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                app:cornerRadius="8dp"
                app:backgroundTint="?attr/colorPrimary" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="?attr/colorSurfaceVariant"
        android:elevation="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNavHome"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="HOME"
            android:textColor="?attr/colorPrimary"
            app:icon="@android:drawable/ic_menu_preferences"
            app:iconGravity="textTop"
            app:iconTint="?attr/colorPrimary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNavProfile"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="PROFILE"
            android:textColor="?attr/colorOutline"
            app:icon="@android:drawable/ic_menu_myplaces"
            app:iconGravity="textTop"
            app:iconTint="?attr/colorOutline" />
    </LinearLayout>

</RelativeLayout>